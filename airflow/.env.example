# Copy to .env and fill in. .env must be gitignored (keeps account id/ARNs out
# of version control). Values come from: cd ../terraform && terraform output

# terraform output -raw gold_bucket_name
GOLD_BUCKET=
# terraform output -raw glue_transform_role_arn
GLUE_ROLE_ARN=
AWS_REGION=eu-central-1

# Absolute HOST paths — the dbt DockerOperator bind-mounts these into the dbt
# container (DockerOperator spawns a sibling container on the host daemon, so
# these are host paths, not in-container paths).
#   e.g. /Users/nhitran3315/financial-data-lakehouse/dbt_modeling
DBT_PROJECT_DIR=
#   e.g. /Users/nhitran3315/.aws
AWS_CREDS_DIR=

# Your host user id so Airflow writes logs with the right ownership (run: id -u)
AIRFLOW_UID=50000

# Shared by the webserver + scheduler containers. SECRET_KEY signs log-fetch
# URLs (must match across containers); FERNET_KEY encrypts stored connections.
# Fine to leave the compose defaults for local-only use. Generate real ones with:
#   AIRFLOW_SECRET_KEY=$(python -c 'import secrets; print(secrets.token_hex(16))')
#   AIRFLOW_FERNET_KEY=$(python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())')
AIRFLOW_SECRET_KEY=
AIRFLOW_FERNET_KEY=
